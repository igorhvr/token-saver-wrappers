#!/usr/bin/env bash
# build-and-install — build the vendored headroom container image and install
# the pi-token-saver / hermes-token-saver wrappers into ~/.local/bin.
#
# Usage: ./build-and-install [--rebuild]
#   --rebuild  force a rebuild of the headroom image even if it already exists

set -euo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOKEN_SAVER_HOME="${TOKEN_SAVER_HOME:-$HOME/.local/share/token-saver}"
BIN_DIR="${TOKEN_SAVER_BIN_DIR:-$HOME/.local/bin}"
MITM_IMAGE="${TOKEN_SAVER_MITM_IMAGE:-docker.io/mitmproxy/mitmproxy:12.1.2}"
REBUILD=0
[ "${1:-}" = "--rebuild" ] && REBUILD=1

log() { printf '[build-and-install] %s\n' "$*" >&2; }
die() { log "ERROR: $*"; exit 1; }

# Prefetch the ONNX Runtime static lib that headroom's Rust deps (fastembed /
# ort-sys) download from cdn.pyke.io at build time, and patch the extracted
# Dockerfile to link it via ORT_LIB_LOCATION instead of downloading. Needed
# behind a TLS-intercepting corporate proxy (e.g. a corporate TLS-inspecting proxy) where ort's
# rustls-webpki downloader rejects the proxy's CA: the host trusts the proxy CA
# and can fetch the file, then hands it to the build offline. The vendored
# tarball is left untouched — only the extracted build copy is patched.
# $1 = extracted headroom source dir (build context).
prefetch_ort() {
    local ctx="$1" triple url pf="$1/.ort-prefetch"
    case "$(uname -m)" in
        arm64|aarch64) triple="aarch64-unknown-linux-gnu" ;;
        x86_64|amd64)  triple="x86_64-unknown-linux-gnu" ;;
        *) die "unknown arch $(uname -m) for ort prefetch" ;;
    esac
    # ort-sys 2.0.0-rc.12 pins ONNX Runtime ms@1.24.2 (from the build's
    # download URL). Override via TOKEN_SAVER_ORT_URL if the vendored headroom
    # bumps ort.
    url="${TOKEN_SAVER_ORT_URL:-https://cdn.pyke.io/0/pyke:ort-rs/ms@1.24.2/${triple}.tar.lzma2}"
    log "prefetching ONNX Runtime for offline build ($triple)"
    rm -rf "$pf"; mkdir -p "$pf/lib"
    curl -fsSL -o "$pf/ort.tar.lzma2" "$url" \
        || die "failed to download ONNX Runtime from $url"
    ORT_PF_DIR="$pf" python3 - <<'PY' || die "failed to extract ONNX Runtime"
import lzma, tarfile, io, os
pf = os.environ["ORT_PF_DIR"]
data = open(os.path.join(pf, "ort.tar.lzma2"), "rb").read()
# pyke ships a raw LZMA2 stream (64 MiB dict), not a standard .xz container.
dec = lzma.decompress(data, format=lzma.FORMAT_RAW,
                      filters=[{"id": lzma.FILTER_LZMA2, "dict_size": 1 << 26}])
tf = tarfile.open(fileobj=io.BytesIO(dec))
tf.extractall(pf)
# ort looks for the lib under ORT_LIB_LOCATION and/or its lib/ subdir; put a
# copy in both so either lookup succeeds.
import shutil
lib = os.path.join(pf, "libonnxruntime.a")
if os.path.isfile(lib):
    shutil.copy(lib, os.path.join(pf, "lib", "libonnxruntime.a"))
PY
    rm -f "$pf/ort.tar.lzma2"
    [ -f "$pf/libonnxruntime.a" ] || die "ONNX Runtime lib missing after extract"
    # Insert the COPY + ENV into the builder stage, right before the wheel build.
    ORT_CTX="$ctx" python3 - <<'PY' || die "failed to patch Dockerfile for ort"
import os
df = os.path.join(os.environ["ORT_CTX"], "Dockerfile")
src = open(df).read()
anchor = "ARG HEADROOM_EXTRAS=proxy,code\n"
inject = (anchor
          + "# token-saver: use prefetched ONNX Runtime (offline; corporate TLS proxy).\n"
          + "COPY .ort-prefetch /opt/ort\n"
          + "ENV ORT_LIB_LOCATION=/opt/ort\n")
if "ORT_LIB_LOCATION=/opt/ort" not in src:
    if anchor not in src:
        raise SystemExit("Dockerfile anchor not found")
    open(df, "w").write(src.replace(anchor, inject, 1))
PY
    log "ort prefetch ready; build will link it offline"
}

# Resolve a PEM of corporate MITM-proxy CA certificate(s) to trust inside the
# build container, or empty if none. On macOS the certs are auto-extracted
# from the System keychain (corporate roots that a managed device
# already trusts); override or supply on Linux via TOKEN_SAVER_CORP_CA=<path>.
resolve_corp_ca() {
    if [ -n "${TOKEN_SAVER_CORP_CA:-}" ]; then
        [ -f "$TOKEN_SAVER_CORP_CA" ] || die "TOKEN_SAVER_CORP_CA not found: $TOKEN_SAVER_CORP_CA"
        printf '%s\n' "$TOKEN_SAVER_CORP_CA"; return 0
    fi
    [ "$OS" = "Darwin" ] || return 0
    local out; out="$(mktemp)"
    { security find-certificate -a -c corp-proxy  -p /Library/Keychains/System.keychain 2>/dev/null
      security find-certificate -a -c corp-proxy -p /Library/Keychains/System.keychain 2>/dev/null
    } > "$out"
    if grep -q "BEGIN CERT" "$out"; then printf '%s\n' "$out"; else rm -f "$out"; fi
}

# Patch the extracted Dockerfile to install a corporate CA in the builder stage
# so curl/rustup/cargo trust the MITM proxy (ort still needs prefetch since its
# rustls-webpki downloader ignores the system trust store).
# $1 = build context dir, $2 = path to CA PEM.
inject_corp_ca() {
    local ctx="$1" ca="$2"
    cp "$ca" "$ctx/.corp-ca.crt"
    CA_CTX="$ctx" python3 - <<'PY' || die "failed to patch Dockerfile for corporate CA"
import os
df = os.path.join(os.environ["CA_CTX"], "Dockerfile")
src = open(df).read()
anchor = "RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs"
inject = ("# token-saver: trust corporate MITM-proxy CA for build downloads.\n"
          "COPY .corp-ca.crt /usr/local/share/ca-certificates/corp-mitm.crt\n"
          "RUN update-ca-certificates\n"
          "ENV CARGO_HTTP_CAINFO=/etc/ssl/certs/ca-certificates.crt\n")
if "corp-mitm.crt" not in src:
    if anchor not in src:
        raise SystemExit("Dockerfile rustup anchor not found")
    open(df, "w").write(src.replace(anchor, inject + anchor, 1))
PY
    log "corporate CA will be trusted inside the build container"
}

# --- preflight ---------------------------------------------------------------
OS="$(uname -s)"
command -v podman >/dev/null || die "podman is required"
command -v python3 >/dev/null || die "python3 is required"
command -v curl >/dev/null || die "curl is required"

if [ "$OS" = "Linux" ]; then
    # Rootless podman on Linux needs uid-mapping setup.
    command -v newuidmap >/dev/null || die \
        "newuidmap not found (needed for rootless podman). Install it with: sudo apt-get install -y uidmap"
    grep -q "^$(id -un):" /etc/subuid || die \
        "no /etc/subuid entry for $(id -un). Add one with: sudo usermod --add-subuids 100000-165535 --add-subgids 100000-165535 $(id -un)"

    # Minimal user-level podman config on machines where podman was never set up.
    mkdir -p "$HOME/.config/containers"
    if [ ! -f "$HOME/.config/containers/policy.json" ] && [ ! -f /etc/containers/policy.json ]; then
        log "creating ~/.config/containers/policy.json"
        printf '{\n  "default": [{"type": "insecureAcceptAnything"}]\n}\n' \
            > "$HOME/.config/containers/policy.json"
    fi
    if [ ! -f "$HOME/.config/containers/registries.conf" ] && [ ! -f /etc/containers/registries.conf ]; then
        log "creating ~/.config/containers/registries.conf"
        printf 'unqualified-search-registries = ["docker.io"]\n' \
            > "$HOME/.config/containers/registries.conf"
    fi

    # On filesystems without native-overlay support for rootless containers
    # (e.g. ZFS), podman needs fuse-overlayfs as the overlay mount program.
    STORAGE_FS="$(stat -f -c %T "${XDG_DATA_HOME:-$HOME/.local/share}" 2>/dev/null || echo unknown)"
    if [ "$STORAGE_FS" = "zfs" ] && [ ! -f "$HOME/.config/containers/storage.conf" ]; then
        command -v fuse-overlayfs >/dev/null || die \
            "container storage is on ZFS, which needs fuse-overlayfs. Install it with: sudo apt-get install -y fuse-overlayfs"
        log "creating ~/.config/containers/storage.conf (fuse-overlayfs for ZFS)"
        printf '[storage]\ndriver = "overlay"\n\n[storage.options.overlay]\nmount_program = "/usr/bin/fuse-overlayfs"\n' \
            > "$HOME/.config/containers/storage.conf"
    fi
elif [ "$OS" = "Darwin" ]; then
    # On macOS podman runs Linux containers inside a VM; ensure it is running.
    if ! podman machine inspect >/dev/null 2>&1; then
        log "no podman machine found — creating one (downloads a VM image, several minutes)"
        podman machine init
    fi
    if [ "$(podman machine inspect --format '{{.State}}' 2>/dev/null)" != "running" ]; then
        log "starting podman machine"
        podman machine start
    fi
else
    die "unsupported OS: $OS (only Linux and macOS are supported)"
fi

# --- build headroom image from the vendored tarball --------------------------
HEADROOM_COMMIT="$(cat "$REPO_DIR/vendor/HEADROOM_COMMIT")"
IMAGE_TAG="localhost/headroom-token-saver:${HEADROOM_COMMIT:0:12}"

if [ "$REBUILD" = 1 ] || ! podman image exists "$IMAGE_TAG"; then
    BUILD_DIR="$(mktemp -d)"
    trap 'rm -rf "$BUILD_DIR"' EXIT
    log "extracting vendored headroom source (commit $HEADROOM_COMMIT)"
    tar -xzf "$REPO_DIR/vendor/headroom-src.tar.gz" -C "$BUILD_DIR"
    # Behind a TLS-intercepting corporate proxy (auto-detected on macOS via the
    # keychain, or forced with TOKEN_SAVER_CORP_CA), trust the proxy CA inside
    # the builder so curl/rustup/cargo downloads work.
    CORP_CA="$(resolve_corp_ca || true)"
    [ -n "$CORP_CA" ] && inject_corp_ca "$BUILD_DIR/headroom" "$CORP_CA"
    # macOS (or any host behind such a proxy) also can't let the build container
    # download ONNX Runtime over rustls (webpki-only); prefetch it on the host.
    if [ "$OS" = "Darwin" ] || [ "${TOKEN_SAVER_ORT_PREFETCH:-0}" = "1" ]; then
        prefetch_ort "$BUILD_DIR/headroom"
    fi
    log "building $IMAGE_TAG — first build compiles Rust and may take 10-30+ minutes"
    podman build --target runtime-slim-base -t "$IMAGE_TAG" "$BUILD_DIR/headroom"
else
    log "headroom image $IMAGE_TAG already built (use --rebuild to force)"
fi
podman tag "$IMAGE_TAG" localhost/headroom-token-saver:latest

# --- pull mitmproxy sidecar image ---------------------------------------------
if ! podman image exists "$MITM_IMAGE"; then
    log "pulling $MITM_IMAGE"
    podman pull "$MITM_IMAGE"
fi

# --- install ------------------------------------------------------------------
log "installing library files to $TOKEN_SAVER_HOME/lib"
mkdir -p "$TOKEN_SAVER_HOME/lib" "$BIN_DIR"
install -m 0644 "$REPO_DIR/lib/common.sh" \
                "$REPO_DIR/lib/mitm_addon.py" \
                "$REPO_DIR/lib/gen_intercept_hosts.py" \
                "$TOKEN_SAVER_HOME/lib/"

log "installing wrappers to $BIN_DIR"
install -m 0755 "$REPO_DIR/bin/pi-token-saver" \
                "$REPO_DIR/bin/hermes-token-saver" \
                "$REPO_DIR/bin/token-saver-ctl" \
                "$BIN_DIR/"

case ":$PATH:" in
    *":$BIN_DIR:"*) ;;
    *) log "NOTE: $BIN_DIR is not on your PATH" ;;
esac

log "done. Commands available: pi-token-saver, hermes-token-saver, token-saver-ctl"
log "headroom image: $IMAGE_TAG (from vendored commit $HEADROOM_COMMIT)"
